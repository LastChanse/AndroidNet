<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
		android:layout_width="match_parent"
		android:layout_height="match_parent">

	<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="500px"
    android:layout_centerInParent="true"
	android:background="#333">
		<RelativeLayout
    android:layout_width="328px"
    android:layout_height="81px"
    android:background="@drawable/background_component"
						>
			<TextView
				android:id="@+id/headerText"
				android:layout_width="236px"
				android:layout_height="23px"
				android:layout_marginLeft="20px"
				android:layout_marginTop="16px"
				android:textSize="20px"
				android:textFontWeight="700"
				android:fontFamily="Roboto"
				android:text="Header"
				android:textColor="#333333"/>
			<TextView
				android:id="@+id/subheaderText"
				android:layout_width="236px"
				android:layout_height="16px"
				android:layout_marginLeft="20px"
				android:layout_marginTop="47px"
				android:textSize="14px"
				android:textFontWeight="400"
				android:fontFamily="Roboto"
				android:text="Subheader"
				android:textColor="#9299A2"/>
		</RelativeLayout>
	</LinearLayout>
</LinearLayout>
