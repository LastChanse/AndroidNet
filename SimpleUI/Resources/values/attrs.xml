<?xml version="1.0" encoding="utf-8" ?>
<resources>
	<declare-styleable name="Header">
		<attr name="headerText" format="string" />
		<attr name="subheaderText" format="string" />
		<attr name="image" format="reference" />
		<attr name="buttonText" format="string" />
		<attr name="subheaderVisible" format="boolean" />
		<attr name="buttonVisible" format="boolean" />
	</declare-styleable>

	<declare-styleable name="Item">
		<attr name="title" format="string" />
		<attr name="description" format="string" />
		<attr name="icon" format="reference" />
		<attr name="closeButtonVisible" format="boolean" />
	</declare-styleable>


	<declare-styleable name="HeaderList">
		<attr name="headerText" format="string" />
		<attr name="buttonAddVisible" format="boolean" />
		<attr name="buttonAddText" format="string" />
		<attr name="buttonVisible" format="boolean" />
		<attr name="buttonText" format="string" />
	</declare-styleable>
</resources>