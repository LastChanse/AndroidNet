<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="30dp"
	android:background="#FFF"
	>
	
    <TextView 
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
		android:layout_alignParentTop="true"
        android:textSize="36sp"
        android:text="@string/app_name"
        android:textColor="#000"
        android:layout_marginBottom="16dp"
    />
	
	<View
        android:id="@+id/title_line"
		android:layout_width="match_parent"
	    android:layout_below="@+id/title"
		android:layout_height="2dp"
		android:background="#000"
        android:layout_marginBottom="10dp"/>
	
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
	    android:layout_below="@+id/title_line"
		android:orientation="vertical"
		android:gravity="center"
		android:clipChildren="false"
		>

		<SimpleUI.HeaderView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:subheaderText="Подзаголовок"
	    />

		<SimpleUI.HeaderView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
		app:subheaderVisible="false"
	    />
		
		<SimpleUI.HeaderView
        android:id="@+id/header_component"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
	    app:headerText="Заголовок"
        app:subheaderText="Подзаголовок"
        app:image="@drawable/orange_img"
		app:buttonText="Кнопка"
		app:buttonVisible="true"
	    />

		<SimpleUI.ItemView
			android:clickable="true"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_gravity="center"
	    />
		<SimpleUI.ItemView
			android:id="@+id/item"
			android:clickable="true"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_gravity="center"
			app:title="Элемент"
			app:description="Описание"
			app:closeButtonVisible="true"
	    />
		
		<SimpleUI.HeaderListView
        android:id="@+id/header_list_component"
		android:layout_width="match_parent"
        android:layout_height="match_parent"
	    app:headerText="Список"
		app:buttonAddText="Кнопка"
		app:buttonText="Кнопка"
		app:buttonVisible="true"
		
	    />
		

		<SimpleUI.SimpleButtonView
			android:id="@+id/button1"
			android:clickable="true"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="Кнопка с сообщением"
	    />
	</LinearLayout>

</RelativeLayout>