<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="30dp"
	android:background="#FFF"
	android:clipChildren="false">
	
	<!-- Заголовок -->
    <TextView 
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
		android:layout_alignParentTop="true"
        android:textSize="36sp"
        android:text="@string/app_name"
        android:textColor="#000"
        android:layout_marginBottom="16dp"
    />
	
	<!-- Линия -->
	<View
        android:id="@+id/title_line"
		android:layout_width="match_parent"
	    android:layout_below="@+id/title"
		android:layout_height="2dp"
		android:background="#000"
        android:layout_marginBottom="26dp"/>
	
	<!-- Демонстрация библиотеки -->
	<LinearLayout
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
	    android:layout_below="@+id/title_line"
		android:orientation="vertical"
		android:layout_marginLeft="16dp"
		android:clipChildren="false"
		>

		<!-- Виджет заголовка с подзаголовком -->
		<SimpleUI.Header
        android:id="@+id/component1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:headerText="Заголовок"
        app:subheaderText="Подзаголовок"
        app:image="@drawable/orange_img"
	    />

		<!-- Виджет заголовка без подзаголовком -->
		<SimpleUI.Header
        android:id="@+id/component2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
	    />

		<!-- Виджет элемента -->

		<!-- Виджет элемента с кнопкой закрытия -->


	</LinearLayout>

</RelativeLayout>