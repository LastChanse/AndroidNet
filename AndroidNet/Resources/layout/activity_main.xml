<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="30dp"
	android:background="#FFF"
	>
	
	<!-- Заголовок -->
    <TextView 
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
		android:layout_alignParentTop="true"
        android:textSize="36sp"
        android:text="@string/app_name"
        android:textColor="#000"
        android:layout_marginBottom="16dp"
    />
	
	<!-- Линия -->
	<View
        android:id="@+id/title_line"
		android:layout_width="match_parent"
	    android:layout_below="@+id/title"
		android:layout_height="2dp"
		android:background="#000"
        android:layout_marginBottom="10dp"/>
	
	<!-- Демонстрация библиотеки -->
	<LinearLayout
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
	    android:layout_below="@+id/title_line"
		android:orientation="vertical"
		android:layout_marginLeft="16dp"
		android:gravity="center"
		android:clipChildren="false"
		>

		<!-- Виджет заголовка с подзаголовком -->
		<SimpleUI.HeaderView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:subheaderText="Подзаголовок"
	    />

		<!-- Виджет заголовка без подзаголовком -->
		<SimpleUI.HeaderView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
	    />
		<!-- Виджет заголовка c кнопкой -->
		<SimpleUI.HeaderView
        android:id="@+id/header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
	    app:headerText="Заголовок"
        app:subheaderText="Подзаголовок"
        app:image="@drawable/orange_img"
		app:buttonText="Кнопка"
	    />

		<!-- Виджет элемента -->
		<SimpleUI.ItemView
			android:clickable="true"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
	    />
		<!-- Виджет элемента с кнопкой закрытия -->
		<SimpleUI.ItemView
			android:id="@+id/item"
			android:clickable="true"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			app:title="Элемент"
			app:description="Описание"
			app:closeButtonVisible="true"
	    />
		
		<!-- Виджет кнопки -->

		<SimpleUI.SimpleButtonView
			android:id="@+id/button1"
			android:clickable="true"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="Кнопка с сообщением"
	    />
	</LinearLayout>

</RelativeLayout>