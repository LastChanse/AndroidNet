<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="30dp"
	android:background="#FFF"
	>

	<ScrollView
	android:layout_width="match_parent"
	android:layout_height="wrap_content">
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical"
		android:gravity="center"
		android:clipChildren="false"
		android:paddingTop="20dp"
		android:paddingBottom="50dp"
		>

		<SimpleUI.HeaderView
        android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		app:headerText="Привет мир!"
        app:subheaderText="Привет всем!"
	    />

		<SimpleUI.HeaderView
        android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		app:headerText="Без подписи"
		app:subheaderVisible="false"
	    />
		
		<SimpleUI.HeaderView
        android:id="@+id/header_component"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
	    app:headerText="Заголовок"
        app:subheaderText="Подзаголовок"
        app:image="@drawable/orange_img"
		app:buttonText="Кнопка"
		app:buttonVisible="true"
	    />

		<SimpleUI.ItemView
			android:clickable="true"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_gravity="center"
	    />
		<SimpleUI.ItemView
			android:id="@+id/item"
			android:clickable="true"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_gravity="center"
			app:title="Элемент"
			app:description="Описание"
			app:closeButtonVisible="true"
	    />

		<SimpleUI.HeaderListView
			android:id="@+id/header_list_component1"
			android:layout_width="match_parent"
			android:layout_height="395dp"
			app:headerText="Список"
			app:buttonAddText="Добавить"
			app:buttonText="Кнопка"
			app:buttonVisible="true"
	    />


		<SimpleUI.HeaderListView
			android:id="@+id/header_list_component11"
			android:layout_width="match_parent"
			android:layout_height="340dp"
			app:headerText="Список"
			app:buttonAddText="Добавить"
			app:buttonText="Кнопка"
			app:buttonVisible="false"
	    />


		<SimpleUI.HeaderListView
			android:id="@+id/header_list_component2"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			app:headerText="Список"
			app:buttonAddText="Добавить"
			app:buttonText="Кнопка"
			app:buttonVisible="true"
			app:cardItemMode="true"
	    />


		<SimpleUI.HeaderListView
			android:id="@+id/header_list_component22"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			app:headerText="Список"
			app:buttonAddText="Добавить"
			app:buttonText="Кнопка"
			app:buttonVisible="false"
			app:cardItemMode="true"
	    />
		

		<SimpleUI.SimpleButtonView
			android:id="@+id/button1"
			android:clickable="true"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="Кнопка с сообщением"
			android:layout_margin="16dp"
	    />
	</LinearLayout>
	</ScrollView>

</RelativeLayout>